{
  "version": 2,
  "outputDirectory": "artifacts/matiyane-gas/dist/public",
  "functions": {
    "api/index.mjs": {
      "runtime": "@vercel/node@latest",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.mjs" },
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ]
}
